{
  "name": "@e18e/cli",
  "version": "0.0.1",
  "type": "module",
  "description": "The official e18e CLI",
  "bin": {
    "e18e-cli": "cli.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "browser": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "!lib/test"
  ],
  "scripts": {
    "cli": "node ./lib/cli.js",
    "clean": "premove lib coverage",
    "build:js": "npm run clean && tsc",
    "build": "npm run lint && npm run build:js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run test",
    "generate-fixable-replacements": "node scripts/generate-fixable-replacements.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e18e/cli.git"
  },
  "keywords": [
    "e18e",
    "dependencies",
    "dependency",
    "publint"
  ],
  "author": "e18e Authors (https://e18e.dev)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/e18e/cli/issues"
  },
  "homepage": "https://github.com/e18e/cli#readme",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@e18e/web-features-codemods": "^0.2.0",
    "@publint/pack": "^0.1.4",
    "core-js-compat": "^3.48.0",
    "enginematch": "^0.2.0",
    "fast-wrap-ansi": "^0.2.2",
    "fdir": "^6.5.0",
    "gunshi": "^0.32.0",
    "lockparse": "^0.5.2",
    "module-replacements": "^3.0.0-beta.7",
    "module-replacements-codemods": "^1.2.0",
    "obug": "^2.1.1",
    "package-manager-detector": "^1.6.0",
    "publint": "^0.3.21",
    "semver": "^7.8.1",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/picomatch": "^4.0.3",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "pkg-pr-new": "^0.0.75",
    "premove": "^4.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.0"
  }
}
